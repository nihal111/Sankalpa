{
  "name": "sankalpa",
  "productName": "Sankalpa",
  "version": "1.0.2",
  "description": "Keyboard-first todo app",
  "main": "dist/main/main/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "npm run clean && npm run build:main && concurrently -k \"npm run dev:renderer\" \"npm run dev:main:watch\"",
    "dev:renderer": "vite",
    "dev:main:watch": "wait-on http://localhost:5173 && NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run clean && npm run build:main && vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:hooks": "sh scripts/check-hook-size.sh",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:dev": "playwright test",
    "test:e2e:headless": "npm run build && HEADLESS=1 playwright test",
    "test:e2e:record": "npm run build && RECORD=1 playwright test",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "setup:supabase": "bash scripts/supabase-setup.sh",
    "sync:cloud": "tsx scripts/sync-to-cloud.ts",
    "restore:cloud": "tsx scripts/restore-from-cloud.ts",
    "nuke:cloud": "tsx scripts/nuke-supabase.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.sankalpa.app",
    "productName": "Sankalpa",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@supabase/supabase-js": "^2.98.0",
    "chrono-node": "^2.9.0",
    "dotenv": "^17.3.1",
    "marked": "^17.0.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.0",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "electron": "^40.6.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gifenc": "^1.0.3",
    "happy-dom": "^20.7.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  }
}
