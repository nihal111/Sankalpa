#!/bin/sh
# Electron main process is CommonJS - "type": "module" breaks it
if grep -q '"type":\s*"module"' package.json; then
  echo "ERROR: package.json contains \"type\": \"module\" which breaks Electron main process"
  echo "Remove it - this project uses CommonJS for the main process"
  exit 1
fi

echo "Running type check..."
npx tsc --noEmit || exit 1
echo "Type check passed!"

echo "Running lint..."
npm run lint || exit 1

echo "Checking hook sizes (ADR-0006)..."
npm run lint:hooks || exit 1

echo "Verifying main process builds..."
sh scripts/verify-main-build.sh || exit 1

echo "Running tests with coverage..."
npm run test:coverage 2>/dev/null || { echo "Tests failed! Re-run with: npm run test:coverage"; exit 1; }

echo "All checks passed!"
